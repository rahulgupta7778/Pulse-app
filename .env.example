# Server Port (optional, defaults to 8080/3000)
PORT=3000

# CORS Configuration
CORS_ORIGIN=true

# Google OAuth Integration (for Google Calendar, optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Web Push Notifications (optional)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# JWT Authentication Secret (for signing user tokens)
JWT_SECRET=

# AI Assistants Keys (optional, fallback to local rule-based AI is supported)
GROQ_API_KEY=
GEMINI_API_KEY=
